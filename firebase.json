{
  "hosting": {
    "target": "staging",
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      { "source": "/api/contact", "function": { "functionId": "contactForm", "region": "us-central1" } }
    ],
    "redirects": [
      { "source": "/en/android-16", "destination": "/en/android", "type": 301 },
      { "source": "/en/android-16/", "destination": "/en/android", "type": 301 },
      { "source": "/en/binary-frameworks-in-swift-2", "destination": "/en/binary-frameworks-in-swift", "type": 301 },
      { "source": "/en/binary-frameworks-in-swift-2/", "destination": "/en/binary-frameworks-in-swift", "type": 301 },
      { "source": "/en/lottie-2", "destination": "/en/lottie", "type": 301 },
      { "source": "/en/lottie-2/", "destination": "/en/lottie", "type": 301 },
      { "source": "/en/version-control-best-practices-how-to-keep-your-codebase-clean-and-manageable-2", "destination": "/en/version-control-best-practices-how-to-keep-your-codebase-clean-and-manageable", "type": 301 },
      { "source": "/en/version-control-best-practices-how-to-keep-your-codebase-clean-and-manageable-2/", "destination": "/en/version-control-best-practices-how-to-keep-your-codebase-clean-and-manageable", "type": 301 }
    ],
    "headers": [
      {
        "source": "**/*.@(html|htm)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "**/*.@(js|css|woff|woff2|png|jpg|svg|webp|avif)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs22",
      "ignore": ["node_modules", ".git", "*.log"]
    }
  ]
}
