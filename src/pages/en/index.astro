---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const page = await getEntry('pages', 'homepage-en');
if (!page) throw new Error('homepage-en content missing');
const { Content } = await render(page);
const { metaTitle, metaDescription, h1, subhead, cta, ctaHref } = page.data;
---
<BaseLayout lang="en" metaTitle={metaTitle} metaDescription={metaDescription} isHomepage={true}>
  <header>
    <h1>{h1}</h1>
    {subhead && <p class="subhead">{subhead}</p>}
  </header>
  <Content />
  {cta && ctaHref && <a class="cta" href={ctaHref}>{cta}</a>}
</BaseLayout>
