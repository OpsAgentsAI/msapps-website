    <!-- Case Studies Section -->
    <section id="case-studies" class="bg-dark-alt py-20 md:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-title text-accent">Case Studies</h2>
        <p class="section-subtitle">Showcasing innovation, impact, and technical excellence across diverse industries.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8">
          <div class="case-study-card">
            <div class="case-study-tag">Cybersecurity</div>
            <h3 class="text-2xl font-bold mb-4">CynetAuthenticator</h3>
            <p class="text-gray-400 mb-6">Advanced multi-factor authentication platform built with cutting-edge security protocols. MSApps engineered the mobile client for iOS and Android with seamless UX and enterprise-grade encryption.</p>
            <div class="space-y-2">
              <p class="text-sm"><span class="text-accent font-semibold">Tech Stack:</span> Swift, Kotlin, Cloud Infrastructure</p>
              <p class="text-sm"><span class="text-accent font-semibold">Impact:</span> Deployed to 10,000+ enterprise users</p>
            </div>
          </div>
          <div class="case-study-card">
            <div class="case-study-tag">Healthcare</div>
            <h3 class="text-2xl font-bold mb-4">Theranica Platform</h3>
            <p class="text-gray-400 mb-6">Connected healthcare ecosystem for managing chronic conditions. Integrated IoT wearables, real-time data processing, and AI-driven insights for patient wellness.</p>
            <div class="space-y-2">
              <p class="text-sm"><span class="text-accent font-semibold">Tech Stack:</span> React, Node.js, BLE, ML Pipelines</p>
              <p class="text-sm"><span class="text-accent font-semibold">Impact:</span> Improved patient compliance by 40%</p>
            </div>
          </div>
          <div class="case-study-card">
            <div class="case-study-tag">IoT</div>
            <h3 class="text-2xl font-bold mb-4">Beera Station</h3>
            <p class="text-gray-400 mb-6">Smart beverage dispensing system powered by MSApps IoT architecture. Custom embedded firmware, WiFi connectivity, and cloud-based inventory management.</p>
            <div class="space-y-2">
              <p class="text-sm"><span class="text-accent font-semibold">Tech Stack:</span> Embedded C, WiFi, Cloud APIs</p>
              <p class="text-sm"><span class="text-accent font-semibold">Impact:</span> 500+ units deployed nationwide</p>
            </div>
          </div>
          <div class="case-study-card">
            <div class="case-study-tag">Insurance</div>
            <h3 class="text-2xl font-bold mb-4">Phoenix Young Driver</h3>
            <p class="text-gray-400 mb-6">Telematics insurance platform for young drivers. MSApps built the full mobile app with real-time telemetry tracking, behavioral analytics, and gamified safety incentives.</p>
            <div class="space-y-2">
              <p class="text-sm"><span class="text-accent font-semibold">Tech Stack:</span> Swift, Kotlin, Real-time Analytics</p>
              <p class="text-sm"><span class="text-accent font-semibold">Impact:</span> 20,000+ active users</p>
            </div>
          </div>
