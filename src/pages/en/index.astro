---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import MobileNav from '../../components/MobileNav.astro';
---
<MarketingLayout
  lang="en"
  title="MSApps - AI-Powered Digital Products & Solutions"
  description="MSApps: AI-native software development company building intelligent digital products with Claude AI, custom agents, and cutting-edge mobile & IoT solutions."
  isHomepage={true}
>
  <!-- Navigation -->
  <nav class="nav-sticky">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
      <a href="/en/" class="flex items-center" aria-label="MSApps home">
        <img src="/static/img/brand/msapps-logo-white.png" alt="MSApps — Development House" class="h-10 w-auto" />
      </a>
      <div class="hidden md:flex space-x-8">
        <a href="#services" class="hover:text-accent">Services</a>
        <a href="#ai-expertise" class="hover:text-accent">AI Expertise</a>
        <a href="#case-studies" class="hover:text-accent">Case Studies</a>
        <a href="#about" class="hover:text-accent">About</a>
        <a href="#contact" class="hover:text-accent">Contact</a>
        <a href="/" class="hover:text-accent" hreflang="he" lang="he">עברית</a>
      </div>
      <a href="#contact" class="btn-primary px-6 py-2 rounded-lg text-sm hidden md:inline-flex">Get Started</a>
      <MobileNav lang="en" />
    </div>
  </nav>

  <main id="main-content">
    <!-- Hero Section -->
    <section class="hero-gradient py-20 md:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="max-w-3xl">
          <div class="ai-badge">🚀 AI-Native Software Development</div>
          <h1 class="hero-title">Build Intelligent Digital Products That Think</h1>
          <p class="text-xl text-gray-400 mb-8 leading-relaxed">
            MSApps pioneers AI-first development with Claude, custom agents, and cutting-edge mobile solutions. From iOS to IoT, we engineer the future of intelligent applications.
          </p>
          <div class="flex flex-col sm:flex-row space-y-4 sm:space-y-0 sm:space-x-4">
            <a href="#contact" class="btn-primary px-8 py-3 rounded-lg font-semibold text-center">Start Your Project</a>
            <a href="#services" class="btn-secondary px-8 py-3 rounded-lg font-semibold text-center">Explore Services</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="bg-dark-alt py-20 md:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-title text-accent">Services</h2>
        <p class="section-subtitle">
          Comprehensive AI and development solutions tailored to transform your vision into intelligent, scalable products.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="service-card">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14 2C7.37 2 2 7.37 2 14s5.37 12 12 12 12-5.37 12-12S20.63 2 14 2zm0 22c-5.52 0-10-4.48-10-10s4.48-10 10-10 10 4.48 10 10-4.48 10-10 10zm3.5-9c.83 0 1.5-.67 1.5-1.5S18.33 12 17.5 12 16 12.67 16 13.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S11.33 12 10.5 12 9 12.67 9 13.5 9.67 15 10.5 15zm3.5 6c-2.33 0-4.31-1.46-5.11-3.5h10.22c-.8 2.04-2.77 3.5-5.11 3.5z" fill="#111111"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-3">AI Agents & Automation</h3>
            <p class="text-gray-400">Custom AI agents, Claude API integration, intelligent workflow automation, and autonomous decision-making systems.</p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 9.5c0 .83-.67 1.5-1.5 1.5S11 13.33 11 12.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5zm4 4c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm0-7c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z" fill="#111111"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-3">LLM Integration</h3>
            <p class="text-gray-400">Custom LLM solutions, RAG pipelines, fine-tuning, prompt optimization, and enterprise AI infrastructure.</p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17 2H7c-1.1 0-2 .9-2 2v20c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-5 21c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm5-4H7V4h10v15z" fill="#111111"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-3">iOS Development</h3>
            <p class="text-gray-400">Native iOS apps with Swift and SwiftUI. High-performance, user-centric mobile experiences for iPhone and iPad.</p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M16 1H8c-1.66 0-3 1.34-3 3v10c0 1.66 1.34 3 3 3h1v3c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-3h2v3c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-3h1c1.66 0 3-1.34 3-3V4c0-1.66-1.34-3-3-3zm-4 14H9c-.55 0-1-.45-1-1s.45-1 1-1h3c.55 0 1 .45 1 1s-.45 1-1 1zm4-4H8V4h12v7z" fill="#111111"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-3">Android Development</h3>
            <p class="text-gray-400">Kotlin and Jetpack Compose native Android apps. Scalable, modern applications with optimal performance.</p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M11.5 17.5L6 12l5.5-5.5-1.42-1.42L3.16 12l7.92 7.92 1.42-1.42zM16.5 17.5l1.42-1.42L25.84 12l-7.92-7.92L16.5 5.5 22 12l-5.5 5.5z" fill="#111111"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-3">Full Stack & Web</h3>
            <p class="text-gray-400">React, Node.js, cloud architecture. Modern web platforms built for scale, performance, and user engagement.</p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M19 13h-2v-2h2v2zm4-6h-1V5c0-.55-.45-1-1-1h-1c-.55 0-1 .45-1 1v2h-2V5c0-.55-.45-1-1-1h-1c-.55 0-1 .45-1 1v2h-2V5c0-.55-.45-1-1-1H8c-.55 0-1 .45-1 1v2H6c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2zm0 14H6V12h16v9z" fill="#111111"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-3">IoT & Connected Devices</h3>
            <p class="text-gray-400">BLE, WiFi integration, embedded systems, and hardware connectivity. Smart devices powered by intelligent software.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- AI Expertise Section -->
    <section id="ai-expertise" class="bg-dark-base py-20 md:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <div class="ai-badge">Cutting-Edge AI Research</div>
            <h2 class="section-title">AI Native from the Ground Up</h2>
            <p class="section-subtitle">
              MSApps is built for the AI era. We don't just use AI—we architect it into every solution.
            </p>
            <ul class="space-y-4 mb-8">
              <li class="flex items-start"><span class="text-accent mr-3">✓</span><span><strong>Claude Partnership Ready:</strong> Certified development with advanced Claude API integration</span></li>
              <li class="flex items-start"><span class="text-accent mr-3">✓</span><span><strong>MCP Server Development:</strong> Custom Model Context Protocol implementations</span></li>
              <li class="flex items-start"><span class="text-accent mr-3">✓</span><span><strong>AI Security & Ethics:</strong> Responsible AI practices, alignment research</span></li>
              <li class="flex items-start"><span class="text-accent mr-3">✓</span><span><strong>Computer Vision:</strong> Advanced image processing and ML pipelines</span></li>
              <li class="flex items-start"><span class="text-accent mr-3">✓</span><span><strong>Natural Language Processing:</strong> Text understanding, generation, and semantic analysis</span></li>
              <li class="flex items-start"><span class="text-accent mr-3">✓</span><span><strong>Autonomous Agents:</strong> Multi-step reasoning and decision-making systems</span></li>
            </ul>
            <a href="#contact" class="btn-primary px-8 py-3 rounded-lg font-semibold inline-block">Explore AI Solutions</a>
          </div>
          <div class="bg-dark-alt rounded-lg p-8 border border-accent border-opacity-20">
            <h3 class="text-2xl font-bold mb-6">Core AI Capabilities</h3>
            <div class="space-y-3">
              <div><p class="text-sm font-semibold text-accent mb-2">Claude API & LLMs</p><div class="w-full bg-opacity-20 bg-accent rounded-full h-2"><div class="bg-accent h-2 rounded-full" style="width: 95%"></div></div></div>
              <div><p class="text-sm font-semibold text-accent mb-2">Prompt Engineering</p><div class="w-full bg-opacity-20 bg-accent rounded-full h-2"><div class="bg-accent h-2 rounded-full" style="width: 90%"></div></div></div>
              <div><p class="text-sm font-semibold text-accent mb-2">RAG & Knowledge Systems</p><div class="w-full bg-opacity-20 bg-accent rounded-full h-2"><div class="bg-accent h-2 rounded-full" style="width: 88%"></div></div></div>
              <div><p class="text-sm font-semibold text-accent mb-2">Autonomous Agents</p><div class="w-full bg-opacity-20 bg-accent rounded-full h-2"><div class="bg-accent h-2 rounded-full" style="width: 85%"></div></div></div>
              <div><p class="text-sm font-semibold text-accent mb-2">Computer Vision & ML</p><div class="w-full bg-opacity-20 bg-accent rounded-full h-2"><div class="bg-accent h-2 rounded-full" style="width: 82%"></div></div></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Certification Placeholder -->
    <section class="bg-dark-alt py-16 md:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-center space-x-8">
          <div class="text-center">
            <p class="text-sm text-gray-400 mb-4">Certified Partner</p>
            <div class="w-32 h-32 border-2 border-dashed border-accent border-opacity-40 rounded-lg flex items-center justify-center">
              <div class="text-center">
                <p class="text-accent font-bold text-sm">Anthropic</p>
                <p class="text-gray-500 text-xs">Claude Certified</p>
                <p class="text-gray-500 text-xs mt-1">Badge Placeholder</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Clients Section -->
    <section id="clients" class="bg-dark-base py-20 md:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="section-title">Trusted by 60+ Leading Companies</h2>
          <p class="section-subtitle text-center max-w-2xl mx-auto">
            Leading enterprises and innovators across healthcare, cybersecurity, finance, and beyond partner with MSApps.
          </p>
        </div>
        <div class="flex flex-wrap justify-center gap-4 clients-flex">
          <div class="client-badge"><img src="/static/img/clients/partner.jpg" alt="Partner" loading="lazy" /></div>
