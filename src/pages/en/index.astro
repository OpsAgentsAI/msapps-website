          <div class="client-badge"><img src="/static/img/clients/tau.jpg" alt="Tel Aviv University" loading="lazy" /></div>
          <div class="client-badge"><img src="/static/img/clients/zemingo.jpg" alt="Zemingo" loading="lazy" /></div>
          <div class="client-badge"><img src="/static/img/clients/pima.jpg" alt="Pima" loading="lazy" /></div>
          <div class="client-badge"><img src="/static/img/clients/fairfly.jpg" alt="FairFly" loading="lazy" /></div>
          <div class="client-badge"><img src="/static/img/clients/ananey.jpg" alt="Ananey" loading="lazy" /></div>
          <div class="client-badge"><img src="/static/img/clients/sessme.jpg" alt="SessMe" loading="lazy" /></div>
          <div class="client-badge"><img src="/static/img/clients/commit.jpg" alt="Commit" loading="lazy" /></div>
