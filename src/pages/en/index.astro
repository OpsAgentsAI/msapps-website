  <script is:inline>
    (function () {
      const form = document.getElementById('contact-form-en');
      if (!form) return;
      const status = document.getElementById('contact-status-en');
      const button = form.querySelector('button[type="submit"]');
      const endpoint = form.dataset.endpoint || '/api/contact';
      const lang = form.dataset.lang || 'en';
      const COPY = {
        sending: 'Sending...',
        success: 'Thanks! We got your message and will get back to you shortly.',
        error_validation: 'Please fill in every field correctly.',
        error_rate: 'Too many submissions. Please try again in an hour.',
        error_generic: 'Something went wrong. Please try again or email info@msapps.mobi.',
      };
      function setStatus(text, kind) {
        if (!status) return;
        status.textContent = text;
        status.className = 'text-sm text-center min-h-[1.25rem] ' + (kind === 'ok' ? 'text-green-400' : kind === 'err' ? 'text-red-400' : 'text-gray-400');
      }
      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        const fd = new FormData(form);
        const payload = {
          name: (fd.get('name') || '').toString(),
          email: (fd.get('email') || '').toString(),
          phone: (fd.get('phone') || '').toString(),
          message: (fd.get('message') || '').toString(),
          hp_field: (fd.get('hp_field') || '').toString(),
          lang: lang,
        };
        if (button) {
          button.disabled = true;
          button.textContent = button.dataset.submittingLabel || COPY.sending;
        }
        setStatus(COPY.sending, 'pending');
        try {
          const res = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept-Language': lang },
            body: JSON.stringify(payload),
          });
          const data = await res.json().catch(() => ({}));
          if (res.ok && data.ok) {
            setStatus(COPY.success, 'ok');
            form.reset();
          } else if (res.status === 400) {
            setStatus(COPY.error_validation, 'err');
          } else if (res.status === 429) {
            setStatus(COPY.error_rate, 'err');
          } else {
            setStatus(COPY.error_generic, 'err');
          }
        } catch (err) {
          setStatus(COPY.error_generic, 'err');
        } finally {
          if (button) {
            button.disabled = false;
            button.textContent = button.dataset.submitLabel || 'Send Message';
          }
        }
      });
    })();
  </script>
