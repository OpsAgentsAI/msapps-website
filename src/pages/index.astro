---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import MobileNav from '../components/MobileNav.astro';
---
<MarketingLayout
  lang="he"
  title={`MSApps — Mobile 🧡 AI First | מובילים בפיתוח דיגיטלי בישראל`}
  description="16 שנות ניסיון. 40+ מומחים ישראלים. מובייל, ווב, IoT, AI ופלאגיני Claude. שותפים של פניקס, ליברה, יוניון מוטורס, אסותא. בואו נדבר."
  isHomepage={true}
>
  <!-- Navigation -->
  <nav class="nav-sticky">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
      <a href="/" class="flex items-center" aria-label="MSApps — דף הבית">
        <img src="/static/img/brand/msapps-logo-white.png" alt="MSApps — מובילים בפיתוח דיגיטלי" class="h-10 w-auto" />
      </a>
      <div class="hidden md:flex space-x-8 space-x-reverse">
        <a href="#services" class="hover:text-accent">שירותים</a>
        <a href="#ai-expertise" class="hover:text-accent">מומחיות AI</a>
        <a href="#case-studies" class="hover:text-accent">פרויקטים</a>
        <a href="#about" class="hover:text-accent">אודות</a>
        <a href="#contact" class="hover:text-accent">צרו קשר</a>
        <a href="/en/" class="hover:text-accent" hreflang="en" lang="en">English</a>
      </div>
      <a href="#contact" class="btn-primary px-6 py-2 rounded-lg text-sm hidden md:inline-flex">בואו נדבר</a>
      <MobileNav lang="he" />
    </div>
  </nav>

  <main id="main-content">
    <!-- Hero Section -->
    <section class="hero-gradient py-20 md:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="max-w-3xl">
          <div class="ai-badge">🚀 16 שנות מצוינות · Mobile 🧡 AI First</div>
          <h1 class="hero-title">מובילים בפיתוח פתרונות דיגיטליים Mobile 🧡 AI First בישראל</h1>
          <p class="text-xl text-gray-400 mb-8 leading-relaxed">
            16 שנות ניסיון בחזית הטכנולוגיה. 40+ מומחים ישראלים. מאפליקציות פיננסיות מתוחכמות ועד מערכות IoT וסוכני AI — אנחנו הופכים רעיונות מורכבים למציאות עבור החברות המובילות במשק.
          </p>
          <div class="flex flex-col sm:flex-row space-y-4 sm:space-y-0 sm:space-x-4 sm:space-x-reverse">
            <a href="#contact" class="btn-primary px-8 py-3 rounded-lg font-semibold text-center">בואו נדבר על הפרויקט</a>
            <a href="#services" class="btn-secondary px-8 py-3 rounded-lg font-semibold text-center">לכל השירותים</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="bg-dark-alt py-20 md:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-title text-accent">שירותים</h2>
        <p class="section-subtitle">
          פתרונות AI ופיתוח מקצה לקצה, מותאמים אישית להפיכת החזון שלך למוצר חכם וניתן להרחבה.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="service-card">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14 2C7.37 2 2 7.37 2 14s5.37 12 12 12 12-5.37 12-12S20.63 2 14 2zm0 22c-5.52 0-10-4.48-10-10s4.48-10 10-10 10 4.48 10 10-4.48 10-10 10zm3.5-9c.83 0 1.5-.67 1.5-1.5S18.33 12 17.5 12 16 12.67 16 13.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S11.33 12 10.5 12 9 12.67 9 13.5 9.67 15 10.5 15zm3.5 6c-2.33 0-4.31-1.46-5.11-3.5h10.22c-.8 2.04-2.77 3.5-5.11 3.5z" fill="#111111"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-3">סוכני AI ואוטומציה</h3>
            <p class="text-gray-400">סוכנים אוטונומיים מותאמים, אינטגרציית Claude API, אוטומציית תהליכי עבודה חכמים ומערכות החלטה אוטונומיות.</p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 9.5c0 .83-.67 1.5-1.5 1.5S11 13.33 11 12.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5zm4 4c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm0-7c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z" fill="#111111"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-3">אינטגרציית LLM</h3>
            <p class="text-gray-400">פתרונות LLM מותאמים, צינורות RAG, fine-tuning, אופטימיזציית prompt ותשתית AI ארגונית.</p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17 2H7c-1.1 0-2 .9-2 2v20c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-5 21c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm5-4H7V4h10v15z" fill="#111111"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-3">פיתוח iOS</h3>
            <p class="text-gray-400">אפליקציות iOS נטיביות ב-Swift ו-SwiftUI. חוויות מובייל מהירות וממוקדות-משתמש לאייפון ולאייפד.</p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M16 1H8c-1.66 0-3 1.34-3 3v10c0 1.66 1.34 3 3 3h1v3c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-3h2v3c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-3h1c1.66 0 3-1.34 3-3V4c0-1.66-1.34-3-3-3zm-4 14H9c-.55 0-1-.45-1-1s.45-1 1-1h3c.55 0 1 .45 1 1s-.45 1-1 1zm4-4H8V4h12v7z" fill="#111111"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-3">פיתוח Android</h3>
            <p class="text-gray-400">אפליקציות Android נטיביות ב-Kotlin ו-Jetpack Compose. אפליקציות מודרניות, ניתנות להרחבה וביצועים מיטביים.</p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M11.5 17.5L6 12l5.5-5.5-1.42-1.42L3.16 12l7.92 7.92 1.42-1.42zM16.5 17.5l1.42-1.42L25.84 12l-7.92-7.92L16.5 5.5 22 12l-5.5 5.5z" fill="#111111"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-3">Full Stack וווב</h3>
            <p class="text-gray-400">React, Node.js, ארכיטקטורת ענן. פלטפורמות ווב מודרניות שבונות לסקייל, ביצועים ומעורבות משתמש.</p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M19 13h-2v-2h2v2zm4-6h-1V5c0-.55-.45-1-1-1h-1c-.55 0-1 .45-1 1v2h-2V5c0-.55-.45-1-1-1h-1c-.55 0-1 .45-1 1v2h-2V5c0-.55-.45-1-1-1H8c-.55 0-1 .45-1 1v2H6c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2zm0 14H6V12h16v9z" fill="#111111"/></svg>
            </div>
            <h3 class="text-xl font-bold mb-3">IoT ומכשירים מחוברים</h3>
            <p class="text-gray-400">BLE, אינטגרציית WiFi, מערכות משובצות וחיבוריות חומרה. מכשירים חכמים שמופעלים על-ידי תוכנה אינטליגנטית.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- AI Expertise Section -->
    <section id="ai-expertise" class="bg-dark-base py-20 md:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <div class="ai-badge">מחקר AI מתקדם</div>
            <h2 class="section-title">AI-Native מהיסוד</h2>
            <p class="section-subtitle">
              MSApps נבנתה לעידן ה-AI. אנחנו לא רק משתמשות ב-AI — אנחנו מארכיטקטות אותו בכל פתרון.
            </p>
            <ul class="space-y-4 mb-8">
              <li class="flex items-start"><span class="text-accent ml-3">✓</span><span><strong>שותפות Claude:</strong> פיתוח מוסמך עם אינטגרציית Claude API מתקדמת</span></li>
              <li class="flex items-start"><span class="text-accent ml-3">✓</span><span><strong>פיתוח שרתי MCP:</strong> מימושי Model Context Protocol מותאמים אישית</span></li>
              <li class="flex items-start"><span class="text-accent ml-3">✓</span><span><strong>אבטחה ואתיקה ב-AI:</strong> מתודולוגיית SOSA — פרקטיקות AI אחראיות</span></li>
              <li class="flex items-start"><span class="text-accent ml-3">✓</span><span><strong>ראיית מחשב:</strong> עיבוד תמונה מתקדם ו-pipeline למידת מכונה</span></li>
              <li class="flex items-start"><span class="text-accent ml-3">✓</span><span><strong>עיבוד שפה טבעית:</strong> הבנה, יצירה וניתוח סמנטי של טקסט</span></li>
              <li class="flex items-start"><span class="text-accent ml-3">✓</span><span><strong>סוכנים אוטונומיים:</strong> מערכות חשיבה רב-שלבית וקבלת החלטות</span></li>
            </ul>
            <a href="#contact" class="btn-primary px-8 py-3 rounded-lg font-semibold inline-block">פתרונות AI שלנו</a>
          </div>
          <div class="bg-dark-alt rounded-lg p-8 border border-accent border-opacity-20">
            <h3 class="text-2xl font-bold mb-6">יכולות AI מרכזיות</h3>
            <div class="space-y-3">
              <div><p class="text-sm font-semibold text-accent mb-2">Claude API ו-LLMs</p><div class="w-full bg-opacity-20 bg-accent rounded-full h-2"><div class="bg-accent h-2 rounded-full" style="width: 95%"></div></div></div>
              <div><p class="text-sm font-semibold text-accent mb-2">Prompt Engineering</p><div class="w-full bg-opacity-20 bg-accent rounded-full h-2"><div class="bg-accent h-2 rounded-full" style="width: 90%"></div></div></div>
              <div><p class="text-sm font-semibold text-accent mb-2">RAG ומערכות ידע</p><div class="w-full bg-opacity-20 bg-accent rounded-full h-2"><div class="bg-accent h-2 rounded-full" style="width: 88%"></div></div></div>
              <div><p class="text-sm font-semibold text-accent mb-2">סוכנים אוטונומיים</p><div class="w-full bg-opacity-20 bg-accent rounded-full h-2"><div class="bg-accent h-2 rounded-full" style="width: 85%"></div></div></div>
              <div><p class="text-sm font-semibold text-accent mb-2">ראיית מחשב ו-ML</p><div class="w-full bg-opacity-20 bg-accent rounded-full h-2"><div class="bg-accent h-2 rounded-full" style="width: 82%"></div></div></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Certification Placeholder -->
    <section class="bg-dark-alt py-16 md:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-center space-x-8">
          <div class="text-center">
            <p class="text-sm text-gray-400 mb-4">שותפה מוסמכת</p>
            <div class="w-32 h-32 border-2 border-dashed border-accent border-opacity-40 rounded-lg flex items-center justify-center">
              <div class="text-center">
                <p class="text-accent font-bold text-sm">Anthropic</p>
                <p class="text-gray-500 text-xs">Claude Certified</p>
                <p class="text-gray-500 text-xs mt-1">Badge Placeholder</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Clients Section -->
    <section id="clients" class="bg-dark-base py-20 md:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="section-title">60+ חברות סומכות עלינו</h2>
          <p class="section-subtitle text-center max-w-2xl mx-auto">
            ארגונים מובילים ומחדשים בבריאות, סייבר, פיננסים ועוד — בוחרים ב-MSApps כשותפה.
          </p>
        </div>
        <div class="flex flex-wrap justify-center gap-4 clients-flex">
          <div class="client-badge"><img src="/static/img/clients/partner.jpg" alt="Partner" loading="lazy" /></div>
