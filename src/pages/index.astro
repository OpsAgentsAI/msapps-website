    <!-- Case Studies Section -->
    <section id="case-studies" class="bg-dark-alt py-20 md:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="section-title text-accent">פרויקטים נבחרים</h2>
        <p class="section-subtitle">חדשנות, אימפקט ומצוינות טכנית במגוון תעשיות.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8">
          <div class="case-study-card">
