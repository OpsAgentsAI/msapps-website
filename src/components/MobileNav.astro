---
interface Props {
  lang: 'he' | 'en';
}
const { lang } = Astro.props;

const copy = {
  he: {
    open: 'פתחי תפריט',
    close: 'סגרי תפריט',
    services: 'שירותים',
    aiExpertise: 'מומחיות AI',
    cases: 'פרויקטים',
    about: 'אודות',
    contact: 'צרי קשר',
    langSwitch: 'English',
    langHref: '/en/',
    cta: 'בואי נדבר',
  },
  en: {
    open: 'Open menu',
    close: 'Close menu',
    services: 'Services',
    aiExpertise: 'AI Expertise',
    cases: 'Case Studies',
    about: 'About',
    contact: 'Contact',
    langSwitch: 'עברית',
    langHref: '/',
    cta: "Let's talk",
  },
}[lang];
---
<button
  type="button"
  id="mobile-nav-toggle"
  class="mobile-nav-toggle md:hidden"
  aria-label={copy.open}
  aria-expanded="false"
  aria-controls="mobile-nav-drawer"
>
  <span class="hamburger-bar"></span>
  <span class="hamburger-bar"></span>
  <span class="hamburger-bar"></span>
</button>

<div
  id="mobile-nav-drawer"
  class="mobile-nav-drawer"
  data-lang={lang}
  aria-hidden="true"
  hidden
>
  <nav aria-label={lang === 'he' ? 'תפריט ראשי' : 'Primary navigation'}>
    <a href="#services" class="mobile-nav-link" data-close>{copy.services}</a>
    <a href="#ai-expertise" class="mobile-nav-link" data-close>{copy.aiExpertise}</a>
    <a href="#case-studies" class="mobile-nav-link" data-close>{copy.cases}</a>
    <a href="#about" class="mobile-nav-link" data-close>{copy.about}</a>
    <a href="#contact" class="mobile-nav-link" data-close>{copy.contact}</a>
    <a href={copy.langHref} class="mobile-nav-link mobile-nav-lang" hreflang={lang === 'he' ? 'en' : 'he'} lang={lang === 'he' ? 'en' : 'he'}>{copy.langSwitch}</a>
    <a href="#contact" class="btn-primary mobile-nav-cta" data-close>{copy.cta}</a>
  </nav>
</div>

<script>
  (function () {
    const toggle = document.getElementById('mobile-nav-toggle');
    const drawer = document.getElementById('mobile-nav-drawer');
    if (!toggle || !drawer) return;

    const labelOpen = toggle.getAttribute('aria-label') ?? 'Open menu';
    const lang = drawer.getAttribute('data-lang') ?? 'he';
    const labelClose = lang === 'he' ? 'סגרי תפריט' : 'Close menu';

    function focusableItems(): HTMLElement[] {
      return Array.from(
        drawer!.querySelectorAll<HTMLElement>('a[href], button:not([disabled])')
      );
    }

    function open() {
      drawer!.hidden = false;
      // Allow CSS transition to pick up
      requestAnimationFrame(() => drawer!.classList.add('is-open'));
      drawer!.setAttribute('aria-hidden', 'false');
      toggle!.setAttribute('aria-expanded', 'true');
      toggle!.setAttribute('aria-label', labelClose);
      toggle!.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      const items = focusableItems();
      if (items.length) items[0].focus();
      document.addEventListener('keydown', onKeydown);
      drawer!.addEventListener('click', onDrawerClick);
    }

    function close() {
      drawer!.classList.remove('is-open');
      drawer!.setAttribute('aria-hidden', 'true');
      toggle!.setAttribute('aria-expanded', 'false');
      toggle!.setAttribute('aria-label', labelOpen);
      toggle!.classList.remove('is-open');
      document.body.style.overflow = '';
      document.removeEventListener('keydown', onKeydown);
      drawer!.removeEventListener('click', onDrawerClick);
      // Hide after transition completes for a11y tree cleanliness
      window.setTimeout(() => {
        if (!drawer!.classList.contains('is-open')) drawer!.hidden = true;
      }, 220);
      toggle!.focus();
    }

    function onKeydown(e: KeyboardEvent) {
      if (e.key === 'Escape') {
        e.preventDefault();
        close();
        return;
      }
      if (e.key === 'Tab') {
        const items = focusableItems();
        if (!items.length) return;
        const first = items[0];
        const last = items[items.length - 1];
        const active = document.activeElement as HTMLElement | null;
        if (e.shiftKey && active === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && active === last) {
          e.preventDefault();
          first.focus();
        }
      }
    }

    function onDrawerClick(e: MouseEvent) {
      const target = e.target as HTMLElement;
      // Close on backdrop OR on any link tagged data-close
      if (target === drawer || target.hasAttribute('data-close')) {
        close();
      }
    }

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      if (isOpen) close();
      else open();
    });

    // Close drawer if viewport upsizes past md breakpoint
    const mq = window.matchMedia('(min-width: 768px)');
    mq.addEventListener('change', (e) => {
      if (e.matches && toggle.getAttribute('aria-expanded') === 'true') close();
    });
  })();
</script>
