---
import '../styles/global.css';

interface Props {
  lang: 'he' | 'en';
  title: string;
  description: string;
  ogImage?: string;
  isHomepage?: boolean;
}

const { lang, title, description, ogImage, isHomepage = false } = Astro.props;
const dir = lang === 'he' ? 'rtl' : 'ltr';
const siteUrl = 'https://msapps-website-staging.web.app';
const canonical = Astro.url.href;
const ogImg = ogImage ?? `${siteUrl}/og-default.png`;
const ogType = isHomepage ? 'website' : 'article';
const ogLocale = lang === 'he' ? 'he_IL' : 'en_US';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'MSApps Development House',
  url: 'https://msapps.mobi',
  logo: 'https://msapps.mobi/static/img/brand/msapps-logo-white.png',
  description: lang === 'he'
    ? 'חברה ישראלית מובילה בפיתוח פתרונות דיגיטליים — מובייל, ווב, IoT ובינה מלאכותית — לחברות המובילות במשק הישראלי מ-2010.'
    : 'Israeli boutique development house specializing in mobile apps, web applications, AI automation, and team augmentation.',
  foundingDate: '2010',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '6 Galgalei HaPlada',
    addressLocality: 'Herzliya',
    addressCountry: 'IL',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+972544255549',
    email: 'info@msapps.mobi',
    contactType: 'sales',
  },
  sameAs: [
    'https://www.linkedin.com/company/msapps-mobi/',
    'https://www.facebook.com/msapps.mobi',
    'https://github.com/MSApps-Mobile',
  ],
  knowsAbout: [
    'Mobile App Development',
    'Web Application Development',
    'AI Automation',
    'Claude Plugins',
    'SOSA Methodology',
    'Team Augmentation',
  ],
};
---
<!DOCTYPE html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#E8611A" />

    <link rel="alternate" hreflang="he" href={lang === 'he' ? canonical : new URL('/', siteUrl).href} />
    <link rel="alternate" hreflang="en" href={lang === 'en' ? canonical : new URL('/en/', siteUrl).href} />
    <link rel="alternate" hreflang="x-default" href={new URL('/en/', siteUrl).href} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImg} />
    <meta property="og:site_name" content="MSApps Development House" />
    <meta property="og:locale" content={ogLocale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImg} />

    {isHomepage && <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+Hebrew:wght@400;500;600;700;800&display=swap" />
  </head>
  <body class="bg-dark-base text-white">
    <a href="#main-content" class="skip-link">{lang === 'he' ? 'דלגי לתוכן' : 'Skip to content'}</a>
    <slot />
  </body>
</html>
