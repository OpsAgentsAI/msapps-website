---
interface Props {
  lang: 'he' | 'en';
  metaTitle: string;
  metaDescription: string;
  ogImage?: string;
  isHomepage?: boolean;
}

const { lang, metaTitle, metaDescription, ogImage, isHomepage = false } = Astro.props;
const dir = lang === 'he' ? 'rtl' : 'ltr';
const siteUrl = 'https://msapps-website-staging.web.app';
const canonical = Astro.url.href;
const ogImg = ogImage ?? `${siteUrl}/og-default.png`;
const ogType = isHomepage ? 'website' : 'article';
const ogLocale = lang === 'he' ? 'he_IL' : 'en_US';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'MSApps Development House',
  url: 'https://msapps.mobi',
  logo: 'https://msapps.mobi/logo.png',
  description: lang === 'he'
    ? 'בית פיתוח בוטיק ישראלי המתמחה באפליקציות מובייל, ווב, בינה מלאכותית והרחבת צוותים.'
    : 'Israeli boutique development house specializing in mobile apps, web applications, AI automation, and team augmentation.',
  foundingDate: '2010',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '6 Galgalei HaPlada',
    addressLocality: 'Herzliya',
    addressCountry: 'IL',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+972544255549',
    email: 'info@msapps.mobi',
    contactType: 'sales',
  },
  sameAs: [
    'https://www.linkedin.com/company/msapps-mobi/',
    'https://www.facebook.com/msapps.mobi',
    'https://github.com/MSApps-Mobile',
  ],
  knowsAbout: [
    'Mobile App Development',
    'Web Application Development',
    'AI Automation',
    'Claude Plugins',
    'SOSA Methodology',
    'Team Augmentation',
  ],
};
---
<!DOCTYPE html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{metaTitle}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonical} />

    <link rel="alternate" hreflang="he" href={lang === 'he' ? canonical : new URL('/', siteUrl).href} />
    <link rel="alternate" hreflang="en" href={lang === 'en' ? canonical : new URL('/en/', siteUrl).href} />
    <link rel="alternate" hreflang="x-default" href={new URL('/en/', siteUrl).href} />

    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImg} />
    <meta property="og:site_name" content="MSApps Development House" />
    <meta property="og:locale" content={ogLocale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metaTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImg} />

    {isHomepage && <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />}

    <style>
      :root {
        --bg: #ffffff;
        --fg: #0a0a0a;
        --muted: #4b5563;
        --accent: #e8611a;
        --accent-hover: #c2410c;
        --max-w: 72ch;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, "Helvetica Neue", Arial, "Noto Sans Hebrew", sans-serif;
        line-height: 1.65;
        font-size: 18px;
      }
      main {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 4rem 1.25rem 6rem;
      }
      header { margin-bottom: 3rem; }
      h1 { font-size: 2.25rem; line-height: 1.2; margin: 0 0 1rem; letter-spacing: -0.01em; }
      h2 { font-size: 1.5rem; line-height: 1.3; margin: 2.5rem 0 0.75rem; }
      .subhead { font-size: 1.2rem; color: var(--muted); margin: 0 0 2rem; }
      ul { padding-inline-start: 1.5rem; }
      li { margin-bottom: 0.5rem; }
      a { color: var(--accent); }
      a:hover { text-decoration: underline; }
      .cta {
        display: inline-block;
        margin-top: 2rem;
        padding: 0.875rem 1.75rem;
        background: var(--accent);
        color: white;
        text-decoration: none;
        border-radius: 6px;
        font-weight: 600;
      }
      .cta:hover { background: var(--accent-hover); text-decoration: none; }
      .skip-link { position: absolute; left: -999px; top: auto; width: 1px; height: 1px; overflow: hidden; }
      .skip-link:focus { left: 1rem; top: 1rem; width: auto; height: auto; padding: 0.5rem 1rem; background: var(--fg); color: var(--bg); z-index: 100; }
      nav { font-size: 0.9rem; color: var(--muted); margin-bottom: 2rem; }
      nav a { margin-inline-end: 1rem; color: var(--muted); }
      footer { margin-top: 4rem; padding-top: 2rem; border-top: 1px solid #e5e7eb; font-size: 0.85rem; color: var(--muted); text-align: center; }
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-link">{lang === 'he' ? 'דלגי לתוכן' : 'Skip to content'}</a>
    <main>
      <nav aria-label={lang === 'he' ? 'שפות' : 'Languages'}>
        <a href="/" hreflang="he" lang="he">עברית</a>
        <a href="/en/" hreflang="en" lang="en">English</a>
      </nav>
      <div id="main-content">
        <slot />
      </div>
      <footer>
        © {new Date().getFullYear()} MSApps · <a href="mailto:info@msapps.mobi">info@msapps.mobi</a> · <a href="https://www.linkedin.com/company/msapps-mobi/">LinkedIn</a> · <a href="https://github.com/MSApps-Mobile">GitHub</a>
      </footer>
    </main>
  </body>
</html>
